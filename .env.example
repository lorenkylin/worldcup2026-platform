# 2026 世界杯赛事分析平台 · 环境变量示例
# 复制为 .env 后填入真实值 (Fly.io 部署请用 ./fly_secrets_set.sh 注入)

# === 核心应用配置 ===
APP_NAME=2026 FIFA World Cup 赛事分析平台
# 本地开发开 debug; 生产/Fly 务必 false
DEBUG=true

# 管理员 Token,用于手动比分/赔率等敏感接口 (生产至少 16 字符)
ADMIN_TOKEN=your-secure-admin-token

# 数据库路径. v0.13 支持 DATA_DIR 环境变量覆盖,便于容器/云持久卷挂载.
# 本地默认 ./data; Fly.io 上 fly.toml 已设 DATA_DIR=/data,此处留空即可.
DATABASE_URL=sqlite:///./data/worldcup2026.db
DATA_DIR=./data

# === 数据同步配置 ===
# worldcup26.ir 主源轮询间隔(秒),默认 900(15 分钟)
SYNC_INTERVAL_SECONDS=900
# 主源 API 根地址(一般无需改动)
WC26_BASE_URL=https://worldcup26.ir

# === football-data.co 元数据接入 (v0.5.1) ===
# 免费层: 10 req/min,无赔率端点. 不填 key 则自动跳过.
FOOTBALL_DATA_ENABLED=false
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# === API-Football 实时数据主源 (v0.14.0) ===
# 免费层: 100 req/天, 10 req/分. 提供世界杯赛程/比分/事件/阵容/统计.
# 方式 A（推荐）: 直接到 https://www.api-football.com/ 注册，填入 API_FOOTBALL_KEY.
# 方式 B（可选）: 通过 RapidAPI 订阅，填入 RAPIDAPI_KEY 与 RAPIDAPI_HOST.
# 不配置任何 key 时自动回退到 worldcup26.ir,不影响现有功能.
API_FOOTBALL_ENABLED=false
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026
API_FOOTBALL_DAILY_LIMIT=100
API_FOOTBALL_RATE_LIMIT_PER_MIN=10

# RapidAPI 代理模式（可选）. 示例 host: api-football-v1.p.rapidapi.com
# 若填写 RAPIDAPI_KEY，则会通过 RapidAPI 调用 API-Football；否则直接调用 api-sports.io.
RAPIDAPI_KEY=
RAPIDAPI_HOST=

# === 赔率 API 接入 (v0.7.2) ===
# 零预算路线: provider=mock (使用 mock 数据). 有 The Odds API key 可改.
ODDS_API_ENABLED=false
ODDS_API_PROVIDER=mock
ODDS_API_KEY=

# === Elo→Poisson λ 参数 (prediction.py 与 monte_carlo.py 共用) ===
# POISSON_HOME_ADVANTAGE=60.0
# POISSON_BASE_LAMBDA=1.35
# POISSON_GOAL_PER_ELO_DIFF=0.0035
# POISSON_LAMBDA_FLOOR=0.3

# === 时区配置 ===
# DB 统一存 UTC，API/前端按以下时区展示（默认北京时间）
# DISPLAY_TIMEZONE=Asia/Shanghai

# RAPIDAPI_KEY / RAPIDAPI_HOST 已下线，无需配置
# （旧 .env 中若仍保留，配置层会忽略；API-Football 请使用 API_FOOTBALL_*）
